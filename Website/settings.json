{
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "css.validate": false,
  "scss.validate": false,
  "files.associations": {
    "*.scss": "tailwindcss",
    "*.css": "tailwindcss"
  },
  "tailwindCSS.includeLanguages": {
    "plaintext": "ts",
    "html": "html",
    "scss": "scss"
  },
  "tailwindCSS.lint.unknownAtRules": "ignore",
  "tailwindCSS.lint.invalidApply": "ignore"
}
